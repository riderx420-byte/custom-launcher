<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Search Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/search_background">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_search"
            android:layout_gravity="center_vertical"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Search apps..."
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_marginStart="12dp"
            android:layout_gravity="center_vertical"/>
    </LinearLayout>

    <!-- Apps Grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/appsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <!-- Dock -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:background="@color/dock_background"
        android:paddingHorizontal="16dp"
        android:gravity="center">

        <ImageView
            android:id="@+id/dockIcon1"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_phone"
            android:padding="8dp"
            android:layout_margin="4dp"
            android:background="@drawable/dock_icon_bg"/>

        <ImageView
            android:id="@+id/dockIcon2"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_message"
            android:padding="8dp"
            android:layout_margin="4dp"
            android:background="@drawable/dock_icon_bg"/>

        <ImageView
            android:id="@+id/dockIcon3"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_browser"
            android:padding="8dp"
            android:layout_margin="4dp"
            android:background="@drawable/dock_icon_bg"/>

        <ImageView
            android:id="@+id/dockIcon4"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_settings"
            android:padding="8dp"
            android:layout_margin="4dp"
            android:background="@drawable/dock_icon_bg"/>
    </LinearLayout>

</LinearLayout>
